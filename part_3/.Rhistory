# sample proportion
phat <- mean(pulse_df$ghosts == "Yes")
# number of observations that are not missing
n <- sum(!is.na(pulse_df$ghosts))
# margin of error
E <- 1337
# confidence interval
1337
# sample proportion
phat <- mean(pulse_df$ghosts == "Yes")
# number of observations that are not missing
n <- sum(!is.na(pulse_df$ghosts))
# margin of error
E <- qnorm(0.975) * sqrt((phat * (1 - phat)) / n)
# confidence interval
E * 2
# sample proportion
phat <- mean(pulse_df$ghosts == "Yes")
# number of observations that are not missing
n <- sum(!is.na(pulse_df$ghosts))
# margin of error: number of std deviations * std error
E <- qnorm(0.975) * sqrt((phat * (1 - phat)) / n)
# confidence interval
phat + c(-1,1) * E
# subset
ghosts_yes <- pulse_df |> filter(ghosts == "Yes")
# sample statistics
xbar <- mean(ghosts_yes$age, na.rm = TRUE)
s <- sd(ghosts_yes$age, na.rm = TRUE)
n <- sum(!is.na(ghosts_yes$age))
# using the t distribution
# margin of error (here: "df" are degrees of freedom)
E <- qt(0.975, df = n-1)*s/sqrt(n)
# confidence interval
xbar +  c(-1,1) * E

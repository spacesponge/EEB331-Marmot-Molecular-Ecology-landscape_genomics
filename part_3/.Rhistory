N <- length(p_vals)
for(i in 1:N){
this_plot <- vbinom(k_vals, n, p_vals[i]) +
labs(title = "Population Proportion")
ggsave(paste0("images/binom_plot", LETTERS[i], ".png"), this_plot)
}
png_files <- Sys.glob("images/binom_plot*.png")
gifski::gifski(
png_files,
"images/binom_animation.gif",     #output file name
height = 800, width = 800, #you may change the resolution
delay = 1/2                #seconds
)
#| eval: false
n      <- 9
k_vals <- seq(1, 20, by = 1)
p      <- 0.45
N      <- length(k_vals)
for(i in 1:N){
this_plot <- vbinom(k_vals[1:i], N, p) +
labs(title = "Cumulative Probability")
ggsave(paste0("images/pbinom_plot", LETTERS[i], ".png"), this_plot)
}
png_files <- Sys.glob("images/pbinom_plot*.png")
gifski::gifski(
png_files,
"pbinom_animation.gif",    #output file name
height = 800, width = 800, #you may change the resolution
delay = 1/2                #seconds
)
#| eval: false
mu = 0
sigma_vals <- 10 / seq(2, 20, by = 2)
N <- length(sigma_vals)
for(i in 1:N){
this_plot <- vnorm(0.201, mu, sigma_vals[i]) +
labs(title = "Changing Variance") +
xlim(-5, 5)
ggsave(paste0("images/norm_plot", LETTERS[i], ".png"), this_plot)
}

# indicate the response variable (what are we trying to predict)
specify(response = politics) |>
# simulation: (1000 repetitions)
# bootstrap: sampling with replacement
generate(reps = 1000, type = "bootstrap") |>
# for each iteration, calculating the average
calculate(stat = "mean")
# sample mean
xbar <- mean(demo_df$politics, na.rm = TRUE)
# form confidence interval (using std errors)

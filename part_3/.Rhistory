## read in shape file, take out colonies we have no observations from
colony_sf <- st_read("marmot_polygons_wgs84.shp") |>
select(Site, Area_sqm, geometry) |>
filter(Site != c("Avery, Bellview, Stonefil"))
## get centroids
colony_centroids <- st_centroid(colony_sf)
colony_centers <- cbind(colony_centroids, st_coordinates(colony_centroids)) |>
select(X)
## overlay with google earth
plot(colony_centers)
colony_sf |>
ggplot() +
geom_sf(aes(fill = Site)) +
geom_sf(aes(mapping = colony_centroids))
## make matrix of geographic distance
colony_coord <- data.frame(colony_centers$X, colony_centers$Y)
